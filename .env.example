# Web app
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# AI providers
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key

# Optional app configuration
# MODEL_PROVIDER=openai
# SENTRY_DSN=
# POSTHOG_API_KEY=
# POSTHOG_HOST=https://app.posthog.com

# Notes
# - NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY are required for the app to boot.
# - SUPABASE_SERVICE_ROLE_KEY is required for server-side routes that bypass RLS.
# - OPENAI_API_KEY and GEMINI_API_KEY are only required for AI-backed features.
